@page "/settings"
@using PlcDataLogger.Configuration
@inject ConfigStore Store

<h1>Settings</h1>
<p class="sub">Site-wide options: naming, upload schedule, data partitioning and retention.</p>

<div class="form">
    <label>Site name
        <input @bind="_siteName" placeholder="e.g. Planta Norte" />
    </label>
    <p class="muted small">
        Uploaded Parquet partitions are named <code>@Preview()</code>.
    </p>

    <hr class="sep" />

    <label>Upload schedule
        <select @bind="_schedule.Mode">
            <option value="Daily">Daily at a fixed time</option>
            <option value="Weekly">Weekly on a day + time</option>
            <option value="Monthly">Monthly on a day + time</option>
            <option value="Interval">Every N minutes</option>
        </select>
    </label>

    @if (_schedule.Mode == "Interval")
    {
        <label>Run every (minutes)
            <input type="number" min="1" @bind="_schedule.IntervalMinutes" />
        </label>
        <p class="muted small">More frequent = smaller lag but more overhead. e.g. 360 = every 6 hours.</p>
    }
    else
    {
        @if (_schedule.Mode == "Weekly")
        {
            <label>Day of week
                <select @bind="_schedule.DayOfWeek">
                    @for (var d = 0; d < 7; d++)
                    {
                        var dv = d;
                        <option value="@dv">@((DayOfWeek)dv)</option>
                    }
                </select>
            </label>
        }
        @if (_schedule.Mode == "Monthly")
        {
            <label>Day of month (1–28)
                <input type="number" min="1" max="28" @bind="_schedule.DayOfMonth" />
            </label>
        }
        <label>At (local time, HH:mm)
            <input @bind="_schedule.DailyAtLocalTime" placeholder="02:00" />
        </label>
        <p class="muted small">Off-peak times avoid competing with production traffic.</p>
    }

    <hr class="sep" />

    <label>Partition size (hours)
        <input type="number" min="1" @bind="_schedule.PartitionHours" />
    </label>
    <p class="muted small">
        Each upload sends zstd-compressed Parquet files, one per time window of this size (use multiples
        of 24 for days). Must be ≤ the upload period — currently ≤ @($"{_schedule.UploadPeriodHours():0.#}") h.
    </p>

    <label class="check">
        <input type="checkbox" @bind="_schedule.KeepUploadedPartitions" />
        Keep uploaded partition files locally (until older than the retention window)
    </label>
    <p class="muted small">Off (default): delete each partition file right after it uploads successfully.</p>

    <hr class="sep" />

    <label>Retention window (days)
        <input type="number" min="0" @bind="_retentionDays" />
    </label>
    <p class="muted small">
        Readings older than this are pruned locally to manage disk. 0 keeps everything. With an upload
        provider set, a reading is only pruned once it has been uploaded in a partition.
    </p>

    <div class="actions">
        <button class="btn primary" @onclick="Save">Save</button>
    </div>

    @if (_message is not null)
    {
        <p class="@(_ok ? "ok-msg" : "err")">@_message</p>
    }
</div>

<style>
    .sep { border: none; border-top: 1px solid #2a2f3a; margin: 18px 0; }
    .check { display: flex; align-items: center; gap: 8px; }
    .check input[type=checkbox] { width: auto; margin: 0; }
</style>

@code {
    private string _siteName = "";
    private ScheduleConfig _schedule = new();
    private int _retentionDays = 90;
    private bool _ok;
    private string? _message;

    protected override void OnInitialized()
    {
        _siteName = Store.GetSiteName();
        _schedule = Store.GetSchedule();
        _retentionDays = Store.GetRetentionDays();
    }

    private void Save()
    {
        var error = _schedule.Validate();
        if (error is not null)
        {
            _ok = false;
            _message = error;
            return;
        }

        Store.SetSiteName(_siteName);
        Store.SetSchedule(_schedule);
        Store.SetRetentionDays(_retentionDays);

        _siteName = Store.GetSiteName();
        _retentionDays = Store.GetRetentionDays();
        _ok = true;
        _message = $"Saved. Site \"{_siteName}\", {Describe()}, {_schedule.PartitionHours}h partitions, keeping {_retentionDays} day(s).";
    }

    private string Describe() => _schedule.Mode switch
    {
        "Interval" => $"every {Math.Max(1, _schedule.IntervalMinutes)} min",
        "Weekly" => $"weekly on {(DayOfWeek)Math.Clamp(_schedule.DayOfWeek, 0, 6)} at {_schedule.DailyAtLocalTime}",
        "Monthly" => $"monthly on day {_schedule.DayOfMonth} at {_schedule.DailyAtLocalTime}",
        _ => $"daily at {_schedule.DailyAtLocalTime}",
    };

    private string Preview()
    {
        var site = string.IsNullOrWhiteSpace(_siteName) ? "Site" : Sanitize(_siteName.Trim());
        return $"{site}-20260708T0000Z.parquet";
    }

    private static string Sanitize(string name) =>
        string.Concat(name.Select(c => Array.IndexOf(Path.GetInvalidFileNameChars(), c) >= 0 ? '_' : c));
}
