@page "/settings"
@using PlcDataLogger.Configuration
@inject ConfigStore Store

<h1>Settings</h1>
<p class="sub">Site-wide options: naming, upload schedule and how long readings are kept.</p>

<div class="form">
    <label>Site name
        <input @bind="_siteName" placeholder="e.g. Planta Norte" />
    </label>
    <p class="muted small">
        Export files are named <code>@Preview()</code> — one rolling CSV per PLC, overwritten each
        run and re-uploaded over the same cloud file.
    </p>

    <hr class="sep" />

    <label>Upload schedule
        <select @bind="_schedule.Mode">
            <option value="Daily">Daily at a fixed time</option>
            <option value="Interval">Every N minutes</option>
        </select>
    </label>

    @if (_schedule.Mode == "Interval")
    {
        <label>Run every (minutes)
            <input type="number" min="1" @bind="_schedule.IntervalMinutes" />
        </label>
        <p class="muted small">More frequent uploads = smaller lag but more bandwidth. e.g. 360 = every 6 hours.</p>
    }
    else
    {
        <label>Daily at (local time, HH:mm)
            <input @bind="_schedule.DailyAtLocalTime" placeholder="02:00" />
        </label>
        <p class="muted small">Off-peak times avoid competing with production traffic.</p>
    }

    <hr class="sep" />

    <label>Retention window (days)
        <input type="number" min="0" @bind="_retentionDays" />
    </label>
    <p class="muted small">
        Readings older than this are pruned locally to manage disk. 0 keeps everything. When an upload
        provider is set, data is only pruned once it has been uploaded. Note the rolling CSV/cloud copy
        mirrors this window — rows older than retention drop off it too.
    </p>

    <div class="actions">
        <button class="btn primary" @onclick="Save">Save</button>
    </div>

    @if (_message is not null)
    {
        <p class="ok-msg">@_message</p>
    }
</div>

<style>
    .sep { border: none; border-top: 1px solid #2a2f3a; margin: 18px 0; }
</style>

@code {
    private string _siteName = "";
    private ScheduleConfig _schedule = new();
    private int _retentionDays = 90;
    private string? _message;

    protected override void OnInitialized()
    {
        _siteName = Store.GetSiteName();
        _schedule = Store.GetSchedule();
        _retentionDays = Store.GetRetentionDays();
    }

    private void Save()
    {
        Store.SetSiteName(_siteName);
        Store.SetSchedule(_schedule);
        Store.SetRetentionDays(_retentionDays);

        // Re-read to reflect any normalization (trimmed name, clamped retention).
        _siteName = Store.GetSiteName();
        _retentionDays = Store.GetRetentionDays();
        _message = $"Saved. Exports use \"{_siteName}\", {Describe()}, keeping {_retentionDays} day(s).";
    }

    private string Describe() =>
        _schedule.Mode == "Interval"
            ? $"every {Math.Max(1, _schedule.IntervalMinutes)} min"
            : $"daily at {_schedule.DailyAtLocalTime}";

    private string Preview()
    {
        var site = string.IsNullOrWhiteSpace(_siteName) ? "Site" : Sanitize(_siteName.Trim());
        return $"{site}-<PLC>.csv";
    }

    private static string Sanitize(string name) =>
        string.Concat(name.Select(c => Array.IndexOf(Path.GetInvalidFileNameChars(), c) >= 0 ? '_' : c));
}
